# Database (auto-configured by pnpm setup with Docker)
POSTGRES_USER=siteseer
POSTGRES_PASSWORD=change-me-to-a-secure-password
POSTGRES_DB=siteseer
DATABASE_URL=postgresql://siteseer:change-me-to-a-secure-password@localhost:5432/siteseer

# Better Auth
BETTER_AUTH_SECRET=change-me-to-a-random-32-char-secret
BETTER_AUTH_URL=http://localhost:5173

# Environment
NODE_ENV=development
DEMO=false
